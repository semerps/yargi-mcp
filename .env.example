# Environment configuration for Yargı MCP Server
# Copy this file to .env and fill in your actual values

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================

# CORS origins (comma-separated list)
ALLOWED_ORIGINS=*

# Server settings
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=info

# Base URL for the application
BASE_URL=http://localhost:8000

# =============================================================================
# API KEYS (Optional)
# =============================================================================

# Brave Search API key for KVKK search functionality
# Get your API key from: https://brave.com/search/api/
# If not set, KVKK search uses a limited free token automatically
BRAVE_API_TOKEN=

# Tavily API key for BDDK search functionality
# Get your API key from: https://tavily.com/
TAVILY_API_KEY=

# =============================================================================
# USAGE INSTRUCTIONS
# =============================================================================

# 1. Copy this file to .env:
#    cp .env.example .env

# 2. (Optional) Add Brave API token for KVKK search:
#    BRAVE_API_TOKEN=your_brave_api_token

# 3. (Optional) Add Tavily API key for BDDK search:
#    TAVILY_API_KEY=your_tavily_api_key

# 4. Start the server:
#    uv run uvicorn asgi_app:app --host 0.0.0.0 --port 8000
